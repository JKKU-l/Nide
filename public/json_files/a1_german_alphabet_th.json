        {
          "letter": "Ä ä",
          "name": "A-Umlaut",
          "how_to_produce": "ออกเสียงคล้ายสระ \"แอ\"",
          "tts_text": "Ä"
        },
        {
          "letter": "Ö ö",
          "name": "O-Umlaut",
          "how_to_produce": "ทำปากรูปสระ \"โอ\" แต่พยายามออกเสียง \"เอ\"",
          "tts_text": "Ö"
        },
        {
          "letter": "Ü ü",
          "name": "U-Umlaut",
          "how_to_produce": "ทำปากรูปสระ \"อู\" แต่พยายามออกเสียง \"อี\"",
          "tts_text": "Ü"
        },
        {
          "letter": "ß",
          "name": "Eszett (Sharp S)",
          "how_to_produce": "ออกเสียง \"ส\" หนักๆ (เหมือน ss)",
          "tts_text": "ß"
        }
      ]
