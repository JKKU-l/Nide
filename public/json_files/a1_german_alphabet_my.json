    {
      "id": "special_characters",
      "title": "အထူးအက္ခရာများ (Umlauts & Eszett)",
      "description": "ဂျာမန်ဘာသာတွင် အရေးအသားနှင့် အဓိပ္ပာယ်အတွက် အရေးကြီးသော အက္ခရာအထူး ၄ လုံး ရှိပါသည်။",
      "content": [
        {
          "letter": "Ä ä",
          "name": "A-Umlaut",
          "how_to_produce": "\"အဲ\" ဟု အသံထွက်သည်။ (ဥပမာ - Apfel → Äpfel)",
          "tts_text": "Ä"
        },
        {
          "letter": "Ö ö",
          "name": "O-Umlaut",
          "how_to_produce": "နှုတ်ခမ်းကို \"အိုး\" ပုံစံလုပ်ပြီး \"အေး\" ဟု အသံထွက်ရန် ကြိုးစားပါ။",
          "tts_text": "Ö"
        },
        {
          "letter": "Ü ü",
          "name": "U-Umlaut",
          "how_to_produce": "နှုတ်ခမ်းကို \"အူး\" ပုံစံလုပ်ပြီး \"အီး\" ဟု အသံထွက်ရန် ကြိုးစားပါ။",
          "tts_text": "Ü"
        },
        {
          "letter": "ß",
          "name": "Eszett (Sharp S)",
          "how_to_produce": "\"အက်စ်\" အသံပြတ်ပြတ် ထွက်ရသည်။ \"Double S\" နှင့် အတူတူပင် ဖြစ်သည်။",
          "tts_text": "ß"
        }
      ]
