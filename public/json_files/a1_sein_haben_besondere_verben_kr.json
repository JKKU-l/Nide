            ["ich (나)", "bin", "habe", "Ich bin Lehrer. (나는 교사입니다.)"],
            ["du (너)", "bist", "hast", "Hast du Geld? (너 돈 있니?)"],
            ["er/sie/es (그/그녀/그것)", "ist", "hat", "Er ist 5 Jahre alt. (그는 5살입니다.)"],
            ["wir (우리)", "sind", "haben", "Wir haben einen Hund. (우리는 개가 한 마리 있습니다.)"],
            ["ihr (너희들)", "seid", "habt", "Seid ihr neu hier? (너희들 여기 처음이니?)"],
            ["sie/Sie (그들/당신)", "sind", "haben", "Sind Sie verheiratet? (당신은 결혼하셨나요?)"]
          ]
        }
      }
    },
