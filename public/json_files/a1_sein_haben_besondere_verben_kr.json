            ["ich", "möchte", "mag", "weiß", "tue"],
            ["du", "möchtest", "magst", "weißt", "tust"],
            ["er/sie/es", "möchte", "mag", "weiß", "tut"],
            ["wir", "möchten", "mögen", "wissen", "tun"],
