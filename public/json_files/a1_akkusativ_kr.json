  "sections": [
    {
      "id": "what_is_akkusativ",
      "title": "1. 4격(Akkusativ)이란 무엇인가요?",
      "description": "독일어 문장에서 1격(Nominative, 주격)은 문장의 주어(행동을 하는 사람이나 사물)를 나타냅니다. 반면 4격(Accusative, 대격)은 직접 목적어(행동의 대상을 받는 사람이나 사물)를 나타낼 때 사용합니다.",
      "content": {
        "example_sentence": {
          "sentence": "웨이터가 주스를 마십니다.",
          "breakdown": [
            {
              "part": "웨이터 (The waiter)",
              "role": "주어 (1격)"
            },
            {
              "part": "마십니다 (Drinks)",
              "role": "동사"
            },
            {
              "part": "주스를 (A juice)",
              "role": "직접 목적어 (4격)"
            }
          ]
        },
        "golden_rule": {
          "title": "4격의 황금 법칙",
          "description": "4격에서 관사가 변하는 것은 오직 남성 명사뿐입니다. 여성, 중성, 그리고 복수 명사는 1격(주격)일 때와 형태가 똑같습니다.",
          "changes": [
            {
              "gender": "남성 명사의 변화",
              "nominative": "der/ein",
              "accusative": "den/einen"
            },
            {
              "gender": "중성 명사 유지",
              "nominative": "das/ein",
              "accusative": "das/ein"
            },
            {
              "gender": "여성 명사 유지",
              "nominative": "die/eine",
              "accusative": "die/eine"
            },
            {
              "gender": "복수 명사 유지",
              "nominative": "die/--",
              "accusative": "die/--"
            }
          ]
        }
      }
