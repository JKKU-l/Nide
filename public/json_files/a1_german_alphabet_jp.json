    {
      "id": "special_characters",
      "title": "特殊文字 (ウムラウトとエスツェット)",
      "description": "ドイツ語には発音と意味で重要な特殊文字が4つあります。",
      "content": [
        {
          "letter": "Ä ä",
          "name": "Aウムラウト",
          "how_to_produce": "\"エ\" に近い音です。（例：Apfel → Äpfel）",
          "tts_text": "Ä"
        },
        {
          "letter": "Ö ö",
          "name": "Oウムラウト",
          "how_to_produce": "\"オ\" の口の形で \"エ\" を発音します。",
          "tts_text": "Ö"
        },
        {
          "letter": "Ü ü",
          "name": "Uウムラウト",
          "how_to_produce": "\"ウ\" の口の形で \"イ\" を発音します。",
          "tts_text": "Ü"
        },
        {
          "letter": "ß",
          "name": "Eszett (Sharp S)",
          "how_to_produce": "強い「エス」の音です（ssと同じ）。",
          "tts_text": "ß"
        }
      ]
    },
    {
      "id": "diphthongs",
      "title": "二重母音 (Diphthongs)",
      "description": "二重母音は2つの母音が組み合わさって新しい音を作ります。",
      "content": [
        {
          "combination": "ei / ai",
          "sounds_like": "\"アイ\" のような音",
          "examples": "Nein, Mai",
          "tts_text": "EI"
        },
        {
          "combination": "ie",
          "sounds_like": "\"イー\" のような長い音",
          "examples": "Sie, Wien",
          "tts_text": "IE"
        },
        {
          "combination": "eu / äu",
          "sounds_like": "\"オイ\" のような音",
          "examples": "Neu, Häuser",
          "tts_text": "EU"
        },
        {
          "combination": "au",
          "sounds_like": "\"アウ\" のような音",
          "examples": "Haus, Blau",
          "tts_text": "AU"
        }
      ]
    },
    {
      "id": "consonant_combinations",
      "title": "注意が必要な子音の発音",
      "description": "ドイツ語には特別な注意が必要な子音の組み合わせがあります。",
      "content": [
        {
          "combination": "W",
          "description": "英語の \"V\" のように発音します。",
          "tts_text": "W"
        },
        {
          "combination": "V",
          "description": "通常は英語の \"F\" のように発音します。",
          "tts_text": "V"
        },
        {
          "combination": "J",
          "description": "英語の \"Y\" のように発音します。",
          "tts_text": "J"
        },
        {
          "combination": "sch",
          "description": "\"シュ\" のように発音します。（例：Schule）",
          "tts_text": "Schule"
        },
        {
          "combination": "ch",
          "description": "単語によって \"フ\" または \"フ\" のような音になります。",
          "tts_text": "Bach"
        }
      ]
    }
