        },
        {
          "letter": "Ö ö",
          "name": "O-Umlaut",
          "how_to_produce": "Khép môi hình chữ \"O\" nhưng phát âm chữ \"Ê\"",
          "tts_text": "Ö"
        },
        {
          "letter": "Ü ü",
          "name": "U-Umlaut",
